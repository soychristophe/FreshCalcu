# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.

# URL base del Cloudflare Worker (déjalo vacío para usar el valor por defecto en producción)
VITE_API_BASE=

# PIN para eliminar productos (🔴 obligatorio — no tiene fallback seguro)
VITE_DELETE_PIN=

# PIN para editar productos (🔴 obligatorio — no tiene fallback seguro)
VITE_EDIT_PIN=
