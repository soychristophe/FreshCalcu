{
  "name": "freshways-pro",
  "version": "2.0.0",
  "private": true,
  "type": "module",
"scripts": {
    "dev": "vite",
    "clean": "rm -rf dist freshways-pro.zip",
    "build": "npm run clean && tsc --noEmit && vite build && bestzip freshways-pro.zip dist/*",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts --report-unused-disable-directives",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\" index.html"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "bestzip": "^3.0.1",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "dependencies": {
    "@zxing/browser": "^0.2.0"
  }
}
